#
# Stream247 production env
#
# Copy this file to .env and set the required values first.
# Everything else can stay as-is unless you actually need it.
#

# Required
APP_URL=https://stream247.example.com
APP_SECRET=replace-with-a-long-random-secret
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://stream247:replace-with-a-strong-password@postgres:5432/stream247

# Required when using: docker compose --profile proxy up -d
TRAEFIK_HOST=stream247.example.com
TRAEFIK_ACME_EMAIL=admin@example.com

# Recommended
TWITCH_STREAM_KEY=
CHANNEL_TIMEZONE=Europe/Berlin

# Stable release image pins
STREAM247_WEB_IMAGE=ghcr.io/drjakeberg/stream247-web:v1.5.4
STREAM247_WORKER_IMAGE=ghcr.io/drjakeberg/stream247-worker:v1.5.4
STREAM247_PLAYOUT_IMAGE=ghcr.io/drjakeberg/stream247-playout:v1.5.4
STREAM247_RELAY_IMAGE=bluenviron/mediamtx:1.15.4

# Usually leave these as-is
NODE_ENV=production
PORT=3000
POSTGRES_DB=stream247
POSTGRES_USER=stream247
REDIS_URL=redis://redis:6379
MEDIA_LIBRARY_ROOT=/app/data/media
STREAM247_RELAY_ENABLED=1
STREAM247_RELAY_OUTPUT_URL=rtmp://relay:1935/live/program
STREAM247_RELAY_INPUT_URL=rtmp://relay:1935/live/program
STREAM247_UPLINK_INPUT_MODE=hls
STREAM247_PROGRAM_FEED_DIR=/app/data/media/.stream247-program-feed
STREAM247_PROGRAM_FEED_TARGET_SECONDS=2
STREAM247_PROGRAM_FEED_LIST_SIZE=30
STREAM247_PROGRAM_FEED_FAILOVER_SECONDS=10
STREAM247_PLAYOUT_TRANSIENT_GRACE_SECONDS=20
STREAM_OUTPUT_WIDTH=1280
STREAM_OUTPUT_HEIGHT=720
STREAM_OUTPUT_FPS=30
STREAM_SCALE_ENABLED=1
STREAM_CHAT_OVERLAY_ENABLED=0
STREAM_ALERTS_ENABLED=0
SCENE_RENDERER_ENABLED=0
TWITCH_EVENTSUB_SECRET=
TWITCH_SCHEDULE_SYNC_ENABLED=0
TWITCH_VOD_CACHE_ENABLED=1
TWITCH_VOD_CACHE_ALLOW_REMOTE_FALLBACK=0
TWITCH_VOD_CACHE_DOWNLOAD_TIMEOUT_SECONDS=120
TWITCH_VOD_CACHE_RETENTION_HOURS=72
TWITCH_VOD_CACHE_PARTIAL_MAX_AGE_HOURS=6
TWITCH_VOD_CACHE_MAX_BYTES=21474836480
TWITCH_VOD_CACHE_MIN_FREE_BYTES=16106127360
TWITCH_VOD_CACHE_FAILURE_COOLDOWN_SECONDS=1800
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app
TRAEFIK_CERT_RESOLVER=letsencrypt

# Optional advanced output overrides
STREAM_OUTPUT_URL=
STREAM_OUTPUT_KEY=
FFMPEG_BIN=ffmpeg
FFMPEG_PRESET=veryfast
FFMPEG_MAXRATE=4500k
FFMPEG_BUFSIZE=9000k
FFMPEG_AUDIO_BITRATE=160k
PLAYOUT_RECONNECT_HOURS=48

# Optional fallback credentials
# These can also be entered later in the setup wizard or /settings.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_ID=
TWITCH_BOT_ACCESS_TOKEN=
TWITCH_BROADCASTER_ACCESS_TOKEN=
TWITCH_DEFAULT_CATEGORY_ID=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
